{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "awguard inventory",
      "type": "shell",
      "command": "npx awguard@latest . --format inventory",
      "problemMatcher": []
    },
    {
      "label": "awguard scan",
      "type": "shell",
      "command": "npx awguard@latest . --fail-on high",
      "problemMatcher": {
        "owner": "awguard",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": [
          {
            "regexp": "^\\[(?:CRITICAL|HIGH|MEDIUM|LOW)\\] (AWG\\d+) (.*)$",
            "severity": "warning",
            "code": 1,
            "message": 2
          },
          {
            "regexp": "^\\s+(.+):(\\d+)$",
            "file": 1,
            "line": 2
          }
        ]
      }
    }
  ]
}
